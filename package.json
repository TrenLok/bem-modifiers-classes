{
  "name": "@trenlok/bem-modifier-classes",
  "version": "1.0.2",
  "author": "TrenLok",
  "description": "BEM modifier classes is a utility for generating modifier classes according to the BEM methodology",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/TrenLok/bem-modifiers-classes#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TrenLok/bem-modifiers-classes.git"
  },
  "bugs": {
    "url": "https://github.com/TrenLok/bem-modifiers-classes/issues"
  },
  "keywords": [
    "bem"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "pnpm run lint:scripts",
    "lint:scripts": "eslint . --cache",
    "format": "pnpm run format:scripts",
    "format:scripts": "eslint . --cache --fix",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "release": "bumpp"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@rhapsodic/eslint-config": "^1.0.4",
    "@vitest/coverage-v8": "^4.1.6",
    "bumpp": "^11.1.0",
    "eslint": "^10.4.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "tsdown": "^0.22.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.6"
  },
  "lint-staged": {
    "*.{js,ts}": "eslint --cache --fix"
  },
  "packageManager": "pnpm@11.1.3+sha512.c85357fe17ca12dd23dd7071822666dfd7e3cb76fe214e3370b5ea2fb34f2a231185509b63e717f3cd0acb38dd3f8d82bcd5e8172400ae678b70ea4fbed0896d"
}
